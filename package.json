{
  "version": "0.4.0",
  "bin": {
    "linear-workflow": "./scripts/diagnose.mjs"
  },
  "scripts": {
    "validate": "node scripts/validate.mjs",
    "test": "node scripts/behavior.test.mjs",
    "test:profile": "node scripts/profile-behavior.test.mjs",
    "test:cli": "node scripts/cli.test.mjs",
    "test:all": "npm run test && npm run test:profile && npm run test:cli",
    "sync:forge": "node scripts/sync-forge.mjs",
    "verify:forge": "node scripts/sync-forge.mjs --check",
    "sync:schema": "node scripts/generate-schema.mjs",
    "verify:schema": "node scripts/generate-schema.mjs --check",
    "package": "npm run sync:forge && node scripts/package.mjs",
    "install-verify": "node scripts/install-verify.mjs",
    "ci": "npm run package && npm run install-verify && npm run test:all && npm run validate"
  },
  "dependencies": {
    "gitnexus": "^1.6.9"
  },
  "trustedDependencies": [
    "@ladybugdb/core"
  ]
}
